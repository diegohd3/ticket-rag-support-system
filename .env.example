APP_NAME=AI Support Ticket Chatbot
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-API-Key,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
TRUST_X_FORWARDED_FOR=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/support_tickets
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_REINDEX_BATCH_SIZE=50
VECTOR_SEARCH_PROBES=10
OPENAI_TIMEOUT_SECONDS=30.0

SEARCH_CANDIDATE_LIMIT=50
SEMANTIC_CANDIDATE_LIMIT=25
DEFAULT_QUERY_LIMIT=10
MAX_QUERY_LIMIT=100
HYBRID_TEXT_WEIGHT=0.55
HYBRID_SEMANTIC_WEIGHT=0.45
SEMANTIC_SEARCH_ENABLED=true
RERANK_ENABLED=true
RERANK_WINDOW=10
CHAT_MAX_CONTEXT_TICKETS=5

AUTH_TOKEN_SECRET=replace-with-strong-64-char-secret
AUTH_TOKEN_TTL_MINUTES=60
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME=Platform Admin

API_KEY_REQUIRED=false
INTERNAL_API_KEY=
USER_GUARD_ENABLED=true
USER_VIOLATION_THRESHOLD=3

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_REQUESTS=8
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_REQUESTS=40
RATE_LIMIT_SEARCH_REQUESTS=60
RATE_LIMIT_REINDEX_REQUESTS=3
RATE_LIMIT_OPS_REQUESTS=20

SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false

DEMO_ENDPOINT_ENABLED=true

OBSERVABILITY_ENABLED=true
LLM_INPUT_COST_PER_1M_TOKENS=0.0
LLM_OUTPUT_COST_PER_1M_TOKENS=0.0
EMBEDDING_INPUT_COST_PER_1M_TOKENS=0.0
