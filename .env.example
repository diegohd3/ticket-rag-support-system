APP_NAME=AI Support Ticket Chatbot
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/support_tickets
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

SEARCH_CANDIDATE_LIMIT=50
DEFAULT_QUERY_LIMIT=10
MAX_QUERY_LIMIT=100
